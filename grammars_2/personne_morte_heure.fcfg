%start S

S[SEM=<Mort(?pers,?t)>] -> NP[SEM=?pers] VP[SEM=?t]

NP[SEM=?p] -> Nprop[SEM=?p]

VP[SEM=?t] -> V Adj PTIME TIME[SEM=?t]

V -> 'est'
Adj -> 'mort' | 'morte'
PTIME -> 'à'

TIME[SEM=<16>] -> '16h'
TIME[SEM=<17>] -> '17h'
TIME[SEM=<18>] -> '18h'

Nprop[SEM=<Mustard>] -> 'Mustard'
Nprop[SEM=<Scarlett>] -> 'Scarlett'
Nprop[SEM=<Plum>] -> 'Plum'
Nprop[SEM=<White>] -> 'White'
Nprop[SEM=<Green>] -> 'Green'
Nprop[SEM=<Orchid>] -> 'Orchid'
Nprop[SEM=<Black>] -> 'Black'